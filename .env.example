# Salesforce OAuth Configuration
# Get these from your Salesforce Connected App
SALESFORCE_CLIENT_ID=your_consumer_key_here
SALESFORCE_CLIENT_SECRET=your_consumer_secret_here

# Salesforce login URL (use test.salesforce.com for sandboxes)
SALESFORCE_LOGIN_URL=https://login.salesforce.com

# Session secret (generate a random secure string)
SESSION_SECRET=your_random_secret_key_here

# Node environment (set to 'production' in production)
NODE_ENV=development

# Cloudinary Configuration (for image uploads)
# Sign up at https://cloudinary.com to get these credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# Note: Callback URL is automatically determined from the request
# Works with any port (3000, 3001, etc.) and any domain (localhost, Heroku, etc.)
# Just make sure your Salesforce Connected App allows multiple callback URLs
