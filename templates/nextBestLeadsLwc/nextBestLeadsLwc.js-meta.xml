        type="String"
        default="{{{headerTitle}}}"
        label="Header Title"
        description="Main header title"
      />
            <property
        name="headerSubtitle"
        type="String"
        default="{{{headerSubtitle}}}"
        label="Header Subtitle"
        description="Header subtitle text"
      />
