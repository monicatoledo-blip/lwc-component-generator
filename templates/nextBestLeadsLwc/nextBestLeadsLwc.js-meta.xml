        name="lead1Name"
        type="String"
        default="{{{lead1Name}}}"
        label="Lead 1 Name"
        description="Name of first lead"
      />
            <property
        name="lead1Role"
        type="String"
        default="{{{lead1Role}}}"
        label="Lead 1 Role"
        description="Role/Company of first lead"
      />
            <property
        name="lead1Match"
        type="String"
        default="{{{lead1Match}}}"
        label="Lead 1 Match Score"
        description="Match score for first lead"
      />
            <property
        name="lead1Context"
        type="String"
        default="{{{lead1Context}}}"
