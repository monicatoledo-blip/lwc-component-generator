<?xml version="1.0" encoding="UTF-8" ?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Unified Profile Mock</masterLabel>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__RecordPage</target>
        <target>lightning__HomePage</target>
    </targets>
    <targetConfigs>
        <targetConfig
      targets="lightning__RecordPage,lightning__AppPage,lightning__HomePage"
    >
            <property
        name="contactName"
        type="String"
        default="{{{contactName}}}"
        label="Contact Name"
        description="The name of the contact"
      />
            <property
        name="contactTitle"
        type="String"
        default="{{{contactTitle}}}"
        label="Contact Title"
        description="The job title of the contact"
      />
            <property
        name="avatarUrl"
        type="String"
        default="{{{avatarUrl}}}"
        label="Avatar URL"
        description="URL for the profile avatar image"
      />
            <property
        name="badgeText"
        type="String"
        default="{{{badgeText}}}"
        label="Badge Text"
        description="Text displayed in the badge"
      />
            <property
        name="bgColor"
        type="String"
        default="{{{bgColor}}}"
        label="Background Color"
        description="Card background color (hex)"
      />
            <property
        name="textColor"
        type="String"
        default="{{{textColor}}}"
        label="Text Color"
        description="Card text color (hex)"
      />
            <property
        name="badgeBgColor"
        type="String"
        default="{{{badgeBgColor}}}"
        label="Badge Background Color"
        description="Badge background color (hex)"
      />
            <property
        name="badgeTextColor"
        type="String"
        default="{{{badgeTextColor}}}"
        label="Badge Text Color"
        description="Badge text color (hex)"
      />
            <property
        name="engagementTitle"
        type="String"
        default="{{{engagementTitle}}}"
        label="Engagement Title"
        description="Title for the engagement section"
      />
            <property
        name="engagementDescription"
        type="String"
        default="{{{engagementDescription}}}"
        label="Engagement Description"
        description="Description for the engagement section"
      />
            <property
        name="sliderPercentage"
        type="Integer"
        default="{{{sliderPercentage}}}"
        label="Slider Percentage"
        description="Slider fill percentage (0-100)"
      />
            <property
        name="ringPercentage"
        type="Integer"
        default="{{{ringPercentage}}}"
        label="Ring Percentage"
        description="Ring fill percentage (0-100)"
      />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
